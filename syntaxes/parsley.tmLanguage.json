{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Parsley",
  "scopeName": "source.parsley",
  "patterns": [
    { "include": "#frontMatter" },
    { "include": "#comment" },
    { "include": "#legacyComment" },
    { "include": "#blockClose" },
    { "include": "#blockOpen" },
    { "include": "#keywordTag" },
    { "include": "#partialAndVar" },
    { "include": "#output" }
  ],
  "repository": {
    "frontMatter": {
      "patterns": [
        {
          "name": "markup.raw.yaml.front-matter.parsley",
          "begin": "(?<!\\S)---\\n$",
          "end": "^---\\s*$",
          "patterns": [{ "include": "source.yaml" }]
        }
      ]
    },
    "comment": {
      "patterns": [
        {
          "name": "comment.block.parsley",
          "begin": "\\{\\{!--",
          "end": "--\\}\\}"
        },
        {
          "name": "comment.block.parsley",
          "match": "\\{\\{\\s*!(?!<)[\\s\\S]*?\\}\\}"
        }
      ]
    },
    "legacyComment": {
      "name": "comment.block.parsley",
      "begin": "\\(\\*\\*",
      "end": "\\*\\*\\)"
    },
    "blockClose": {
      "name": "meta.function.block.end.parsley",
      "begin": "(\\{\\{~?\\s*(?:\\/|end[-_])(if|each)\\s*)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.parsley" },
        "2": { "name": "keyword.control.parsley" }
      },
      "end": "(~?\\}\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.parsley" }
      }
    },
    "blockOpen": {
      "name": "meta.function.block.start.parsley",
      "begin": "(\\{\\{~?\\s*)(if|each)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.parsley" },
        "2": { "name": "keyword.control.parsley" }
      },
      "end": "(~?\\}\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.parsley" }
      },
      "patterns": [{ "include": "#expressionCore" }]
    },
    "keywordTag": {
      "name": "meta.function.inline.keyword.parsley",
      "begin": "(\\{\\{~?\\s*)(else(?:\\s+if|-if|_if)?|include|meta|set_var)\\b",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.parsley" },
        "2": { "name": "keyword.control.parsley" }
      },
      "end": "(~?\\}\\})",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.parsley" }
      },
      "patterns": [{ "include": "#expressionCore" }]
    },
    "partialAndVar": {
      "name": "meta.function.inline.other.parsley",
      "begin": "(\\{\\{~?\\{*(?:>|!<)*)\\s*(@?[-a-zA-Z0-9_\\./]+)?",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.parsley" },
        "2": { "name": "variable.other.parsley" }
      },
      "end": "(~?\\}\\}\\}*)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.parsley" }
      },
      "patterns": [{ "include": "#expressionCore" }]
    },
    "output": {
      "name": "meta.function.inline.output.parsley",
      "begin": "(\\{\\{\\{?)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.template.begin.parsley" }
      },
      "end": "(\\}\\}\\}?)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.template.end.parsley" }
      },
      "patterns": [{ "include": "#expressionCore" }]
    },
    "braceExpression": {
      "name": "meta.embedded.expression.parsley",
      "begin": "\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.section.embedded.begin.parsley" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.section.embedded.end.parsley" }
      },
      "patterns": [{ "include": "#expressionCore" }]
    },
    "expressionCore": {
      "patterns": [
        { "include": "#comment" },
        { "include": "#legacyComment" },
        { "include": "#braceExpression" },
        { "include": "#modelMethod" },
        { "include": "#constants" },
        { "include": "#variable" },
        { "include": "#operators" },
        { "include": "#stringDouble" },
        { "include": "#stringSingle" },
        { "include": "#number" },
        { "include": "#identifier" }
      ]
    },
    "modelMethod": {
      "match": "\\b([$@]?[A-Za-z_][\\w]*(?:\\.[A-Za-z_][\\w]*)*)\\.(filter|toJSON|json|getImage|getMediaURL|getDate|date|sortBy|orderBy|contains|split|count|first|last|length|lower|upper|trim|reverse|random|urlencode|urldecode|html_entity_decode|escapeForJs|cleanAndTrim|cleanAndLower|htmlentities|join|replace|paragraph|wordCount|truepath|isJSON|isPublished|remoteProcess|cdn|searchformatted|lorem|get|post|search|autoLayout)(?=\\s*\\()",
      "captures": {
        "1": { "name": "variable.other.parsley" },
        "2": { "name": "support.function.parsley" }
      }
    },
    "constants": {
      "name": "constant.language.parsley",
      "match": "\\b(?:true|false|null|undefined)\\b"
    },
    "variable": {
      "name": "variable.other.parsley",
      "match": "(?:[$@][A-Za-z_][\\w]*|\\b(?:this|meta|page|globals|navigation|instance|site|request|settings|get_var|post_var|api|json|xml|gbi)\\b(?:\\.[A-Za-z_][\\w]*)*)"
    },
    "operators": {
      "name": "keyword.operator.parsley",
      "match": "(?:\\|\\||&&|\\|(?!=)|===|!==|==|!=|>=|<=|>|<|!|=|\\b(?:and|or|not|eq|ne|gt|gte|lt|lte|in|contains|where|sort|order|by|limit|like|asc|desc|as|is)\\b)"
    },
    "stringDouble": {
      "name": "string.quoted.double.parsley",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.parsley",
          "match": "\\\\."
        },
        { "include": "#comment" },
        { "include": "#partialAndVar" }
      ]
    },
    "stringSingle": {
      "name": "string.quoted.single.parsley",
      "begin": "'",
      "end": "'",
      "patterns": [
        {
          "name": "constant.character.escape.parsley",
          "match": "\\\\."
        },
        { "include": "#comment" },
        { "include": "#partialAndVar" }
      ]
    },
    "number": {
      "name": "constant.numeric.parsley",
      "match": "\\b\\d+(?:\\.\\d+)?\\b"
    },
    "identifier": {
      "name": "variable.other.readwrite.parsley",
      "match": "\\b[A-Za-z_][\\w]*\\b"
    }
  }
}
